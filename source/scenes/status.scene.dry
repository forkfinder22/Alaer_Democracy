title: Status
new-page: true
is-special: true
on-arrival: {!
if (Q.unemployed) {
    Q.unemployed_2 = Q.unemployed.toFixed(1);
}
if (Q.inflation) {
    Q.inflation_2 = Q.inflation.toFixed(1);
}
Q.economic_growth_2 = '0';
if (Q.economic_growth) {
    Q.economic_growth_2 = Q.economic_growth.toFixed(1);
}
Q.vcrime = 0;
Q.nvcrime = 0;
if (Q.crime) {
    Q.vcrime = (Q.crime*0.25);
    Q.nvcrime = (Q.crime*0.75);
}
Q.population_disp = 0;
if (Q.population) {
    Q.population_disp = Q.population.toFixed(0);
}

Q.rcp_pop = 0;
if (Q.population && Q.rcp_mil) {
    Q.rcp_pop = (Q.population*rcp_mil);
}
!}

