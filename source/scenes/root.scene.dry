@startcpa
choose-if: never
go-to: new_main
on-arrival: {!
Q.started = 1;
Q.month = 1;
Q.year = 0;
Q.time = 1;
Q.month_actions = 0;

Q.party = "CPA";
Q.president_party = "EEA";
Q.president = "";
Q.factions = [''];
Q.classes = ['young_workers', 'mid_workers', 'old_workers', 'young_middle', 'mid_middle', 'old_middle', 'young_rural', 'mid_rural', 'old_rural', 'young_cath', 'mid_cath', 'old_cath', 'young_unemployed', 'mid_unemployed', 'old_unemployed', 'young_dular', 'mid_dular', 'old_dular'];
Q.parties = ['cpa', 'su', 'sa', 'dpa', 'scp', 'ga', 'ba', 'nlp', 'ulcpa', 'nlpa', 'ncpa', 'dp', 'eea', 'ia', 'ap'];
Q.parliament_speaker = "Heinrich Weiß";
Q.parliament_speaker_party = "SA";
Q.head_parliament = "Ashley Davis";
Q.head_parliament_party = "NLP";

Q.young_workers = 14;
Q.mid_workers = 10;
Q.old_workers = 7;

Q.young_middle = 4;
Q.mid_middle = 7;
Q.old_middle = 4;

Q.young_rural = 5;
Q.mid_rural = 12;
Q.old_rural = 7;

Q.young_cath = 6;
Q.mid_cath = 10;
Q.old_cath = 3;

Q.young_unemployed = 2;
Q.mid_unemployed = 0;
Q.old_unemployed = 1;

Q.young_dular = 6;
Q.mid_dular = 1;
Q.old_dular = 1;

Q.population_millions = 200; // Should higher population make higher taxes? Might be a bit complicated 
Q.bd_rate = 0.01; // Multiply population by this number + 1
Q.education_level = 0; // -3 to +3 - nonexistent, very poor, poor, average (0), decent, very good, outstanding
Q.inflation = 2.2; //
Q.unemployment = 3; // young+mid+old unemployed - when this increases, the distribution should be 50% young, 35% old, 5% mid - Just based off personal experience, don't know a lot of middle aged people who don't have a job, and aren't looking for one.
Q.budgetgrowth = 5; // Budget grows by this amount - year
Q.budgetdecr = 4; // Budgets decreases by this amount - year 
Q.budget = 2; // Starter budget

//I think I made it so that it is just workers, rural, and middle for taxes - Dulars, catholics, unemployed, are split across these, middle is technically middle and upper classes. Business taxes is budget per 1 billion profit from industry.
Q.worker_taxes = 1
Q.rural_taxes = 1
Q.middle_taxes = 2
Q.business_taxes = 1

// industry revenue, expenses, in billions. every 1 billion revenue - expenses should roughly equal 1 budget from taxes
// What should the biggest industry be? Lets go with oil.
Q.oil_expenses = 0.200
Q.oil_revenue = 1.200
Q.oil_profit = 1.000 // Provides 1 budget
Q.metal_expenses = 0.300
Q.metal_revenue = 1.100
Q.metal_profit = 0.800 // No budget, despite the revvenue being higher than 1000, becuase of expenses
Q.resources_expenses = 1.300
Q.resources_revenue = 2.000
Q.resources_profit = 0.700

// Police
// Loyalty - Percent - 1 being 100%
Q.national_police_loyalty = 0.5
Q.state1_police_loyalty = 0.5
Q.state2_police_loyalty = 0.5
Q.state3_police_loyalty = 0.5
Q.state4_police_loyalty = 0.5
Q.state5_police_loyalty = 0.5
Q.state6_police_loyalty = 0.5
Q.state7_police_loyalty = 0.5
Q.state8_police_loyalty = 0.5
Q.state9_police_loyalty = 0.5
Q.state10_police_loyalty = 0.5
Q.state11_police_loyalty = 0.5
Q.state12_police_loyalty = 0.5
Q.state13_police_loyalty = 0.5
Q.state14_police_loyalty = 0.5
Q.state15_police_loyalty = 0.5

// Strength
Q.national_police_strength = 50000
Q.state1_police_strength = 2500
Q.state2_police_strength = 2500
Q.state3_police_strength = 2500
Q.state4_police_strength = 2500
Q.state5_police_strength = 2500
Q.state6_police_strength = 2500
Q.state7_police_strength = 2500
Q.state8_police_strength = 2500
Q.state9_police_strength = 2500
Q.state10_police_strength = 2500
Q.state11_police_strength = 2500
Q.state12_police_strength = 2500
Q.state13_police_strength = 2500
Q.state14_police_strength = 2500
Q.state15_police_strength = 2500

// Special Police
Q.special_police = 0
Q.special_police_name = "Not Formed"
Q.special_police_loyalty = "Not Formed"
Q.special_police_strength = "Not Formed"
Q.special_police_training = "Not Formed"

// Training & Equipment - Multiplies strength
Q.national_police_training = 0.2
Q.state1_police_training = 0.1
Q.state2_police_training = 0.1
Q.state3_police_training = 0.1
Q.state4_police_training = 0.1
Q.state5_police_training = 0.1
Q.state6_police_training = 0.1
Q.state7_police_training = 0.1
Q.state8_police_training = 0.1
Q.state9_police_training = 0.1
Q.state10_police_training = 0.1
Q.state11_police_training = 0.1
Q.state12_police_training = 0.1
Q.state13_police_training = 0.1
Q.state14_police_training = 0.1
Q.state15_police_training = 0.1

// Percent that will not abuse their power, take bribes, etc - 1 being 100%
Q.national_police_ethics = 0.3
Q.state1_police_ethics = 0.25
Q.state2_police_ethics = 0.25
Q.state3_police_ethics = 0.25
Q.state4_police_ethics = 0.25
Q.state5_police_ethics = 0.25
Q.state6_police_ethics = 0.25
Q.state7_police_ethics = 0.25
Q.state8_police_ethics = 0.25
Q.state9_police_ethics = 0.25
Q.state10_police_ethics = 0.25
Q.state11_police_ethics = 0.25
Q.state12_police_ethics = 0.25
Q.state13_police_ethics = 0.25
Q.state14_police_ethics = 0.25
Q.state15_police_ethics = 0.25

// Crime - Violent, Nonviolent, White Collar - Percent of the population that does each - 1 being 100%
Q.nv_crime = 0.03 // 3%, drunk driving, illegal drugs, shoplifting, etc
Q.v_crime = 0.001 // 0.1%, muggings, murders, etc
Q.wc_crime = 0.0005 // 0.05%, fraud, scams, impersonation, etc

// Immigration isn't a thing - The only country Alär knows of is itself, having annexed Dula (Where the Dulars are from) around 50 years from start.
// Could space travel be a thing? Then immigration becomes an issue? Currently, Dular rights and similar are like Earth's Queer rights, the right to far right doesn't like them, so they lean left
!}

